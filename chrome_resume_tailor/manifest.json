{
  "manifest_version": 3,
  "name": "Send to Resume Tailor",
  "description": "Capture the current job posting and send it to the local Resume Tailor intake service.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Send to Resume Tailor"
  }
}
