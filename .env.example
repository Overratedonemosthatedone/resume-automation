# .env.example - Copy to .env and fill in your actual values
# DO NOT commit the actual .env file to version control!

# Anthropic API Key (required)
# Get your key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here
# Legacy fallback still works: CLAUDE_API_KEY=sk-ant-your-actual-key-here

# Rezi API Key (optional, for Phase 2)
# Get your key from: https://app.rezi.io/settings/api
REZI_API_KEY=

# Indeed API Key (optional, if using official API)
# Request access at: https://opensource.indeedeng.io/api/
INDEED_API_KEY=

# ============================================================================
# Proxy Settings (optional, not required for the current Chrome intake flow)
# See README.md for the current live workflow
# ============================================================================

# ScraperAPI Key (easiest proxy solution)
# Sign up: https://www.scraperapi.com/
# Cost: $10–50/month (only if needed)
SCRAPER_API_KEY=

# Bright Data Proxy URL
# Sign up: https://www.brightdata.com/
# Format: http://username-sessionid:password@proxy.brightdata.com:33335
BRIGHT_DATA_PROXY_URL=

# Custom Proxy URL
# If using your own proxy service
CUSTOM_PROXY_URL=

# ============================================================================
# Google Drive Backup (optional future expansion, not part of the current live flow)
# ============================================================================

# Google Drive Folder ID (the long string after /folders/ in the URL)
# Example: 1A2B3C4D5E6F7G8H9I0JK1L2M3N4O5P6Q
GOOGLE_DRIVE_FOLDER_ID=

# Path to Google service account JSON file
# Only needed for automated Google Drive backup
GOOGLE_SERVICE_ACCOUNT_JSON=

# ============================================================================
# LinkedIn Credentials (optional, for direct scraping)
# Note: LinkedIn actively blocks scrapers. Use with caution.
# Recommended: Use Selenium browser automation instead
# ============================================================================
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ============================================================================
# Email Configuration (optional, for sending applications)
# ============================================================================
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# ============================================================================
# Other Settings
# ============================================================================
DEBUG_MODE=False
LOG_LEVEL=INFO
